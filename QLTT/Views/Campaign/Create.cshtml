@model QLTT.Models.ViewModels.CampaignCreateViewModel

@{
    ViewData["Title"] = "Tạo chiến dịch kêu gọi từ thiện";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        <label asp-for="Title">Tiêu đề chiến dịch</label>
        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề kêu gọi..." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ReceiverInfo">Thông tin người nhận hỗ trợ</label>
        <input asp-for="ReceiverInfo" class="form-control" placeholder="Nhập tên, địa chỉ, hoàn cảnh..." />
        <span asp-validation-for="ReceiverInfo" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Content">Nội dung kêu gọi</label>
        <textarea asp-for="Content" class="form-control" rows="5" placeholder="Mô tả hoàn cảnh, lý do cần quyên góp..."></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="TargetAmount">Số tiền cần quyên góp (VNĐ)</label>
        <input asp-for="TargetAmount" class="form-control" type="number" min="1000" step="1000" />
        <span asp-validation-for="TargetAmount" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="SuggestedAmount">Gợi ý mức đóng góp (VNĐ)</label>
        <input asp-for="SuggestedAmount" class="form-control" type="number" min="1000" step="1000" />
        <span asp-validation-for="SuggestedAmount" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="EndDate">Ngày kết thúc chiến dịch</label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="form-group mb-4">
        <label asp-for="ImageFile">Ảnh minh họa</label>
        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
        <span asp-validation-for="ImageFile" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">📝 Đăng chiến dịch</button>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
